<a href="/">Ga terug naar de homepagina</a>

<section>
  <h1>Quick scan</h1>

  <form action="/quick-scan" method="post" enctype="multipart/form-data">
    <p>Maak een Quick Scan in 4 stappen.</p>

    <fieldset>
      <legend>1 - Upload foto</legend>
      <label>
        Bestand kiezen
        <input type="file" name="picture" required>
      </label>
      <img src="" alt="" width="60" height="40">
    </fieldset>

    <fieldset>
      <legend>2 - Locatie & Tijd</legend>

      <label>
        Stad
        <select name="city" required>
          <option value="">-- Kies een stad --</option>
          <option value="Amsterdam">Amsterdam</option>
          <option value="Breda">Breda</option>
          <option value="Haarlem">Haarlem</option>
          <option value="'s-Hertogenbosch">'s-Hertogenbosch</option>
        </select>
      </label>

      <label>
        Adres
        <input type="text" name="address" required autocapitalize="on">
      </label>

      <label>
        Lengte (in cm)
        <input type="number" name="length" placeholder="210" required>
      </label>

      <label>
        Tijd
        <input type="time" name="time" required>
      </label>
    </fieldset>

    <fieldset>
      <legend>3 - Monitoring & Smart zone</legend>

      <fieldset>
        <legend>Geschiktheid Monitoring</legend>
        <label>
          Geschikt
          <input type="radio" name="monitoring_suitability" value="geschikt">
        </label>

        <label>
          Neutraal
          <input type="radio" name="monitoring_suitability" value="neutraal">
        </label>

        <label>
          Ongeschikt
          <input type="radio" name="monitoring_suitability" value="ongeschikt">
        </label>
      </fieldset>

      <fieldset>
        <legend>Geschiktheid Smart zone</legend>
        <label>
          Geschikt
          <input type="radio" name="smartzone_suitability" value="geschikt">
        </label>

        <label>
          Neutraal
          <input type="radio" name="smartzone_suitability" value="neutraal">
        </label>

        <label>
          Ongeschikt
          <input type="radio" name="smartzone_suitability" value="ongeschikt">
        </label>
      </fieldset>
    </fieldset>

    <fieldset>
      <legend>4 - Observaties</legend>

      <fieldset>
        <legend>Status</legend>
        <label>
          Vrij
          <input type="radio" name="status" value="vrij">
        </label>

        <label>
          Bezet
          <input type="radio" name="status" value="bezet">
        </label>

        <label>
          Overtreding
          <input type="radio" name="status" value="overtreding">
        </label>

        <label>
          Bestaat niet
          <input type="radio" name="status" value="bestaat-niet">
        </label>
      </fieldset>
    </fieldset>

    <button type="submit">Toevoegen</button>
  </form>
</section>
